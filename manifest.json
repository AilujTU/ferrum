{
  "manifest_version": 3,
  "name": "Focus Blocker",
  "version": "1.0",
  "icons": {
    "16": "icons/ferrum_icon-16.png",
    "32": "icons/ferrum_icon-32.png",
    "48": "icons/ferrum_icon-48.png",
    "128": "icons/ferrum_icon-128.png"
  },
  "permissions": ["tabs", "scripting", "storage"],
  "host_permissions": ["*://*/*"],
  "background": {
    "service_worker": "scripts/background.js"
  },
  "options_page": "options/options.html"
}